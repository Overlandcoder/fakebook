<%- include("partials/header") %>

<main class="max-w-xl mx-auto mt-4 p-4">
  <% allUsers.forEach(user => { %>
    <% const { followers, posts, comments } = user._count %>
    <div class="max-w-md border-l-2 border-transparent even:border-amber-400 flex flex-col justify-center mb-4 pt-2 p-4 bg-white shadow rounded-lg hover:border-green-300 hover:shadow-md transition-all">
      <a href="/users/<%= user.username %>" class="mx-auto text-lg font-bold text-green-600 hover:text-green-500 transition-all"><%= user.username %></a>
      <div class="flex justify-center mt-2 text-gray-600">
        <div class="flex items-center px-3 sm:px-5 gap-2 border-r <%= followers === 0 ? 'text-gray-400' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" width="1em" height="1em" viewBox="0 0 16 16"><title xmlns="">people</title><path fill="currentColor" d="M15 14s1 0 1-1s-1-4-5-4s-5 3-5 4s1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276c.593.69.758 1.457.76 1.72l-.008.002l-.014.002zM11 7a2 2 0 1 0 0-4a2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0a3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904c.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724c.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0a3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4a2 2 0 0 0 0-4"/></svg>
          <span><%= followers %></span>
        </div>
        <div class="flex items-center px-3 sm:px-5 gap-2 border-r <%= posts === 0 ? 'text-gray-400' : '' %>">
          <svg xmlns="http://w3.org" class="h-5 w-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-pen">
            <path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"/>
          </svg>
          <span><%= posts %></span>
        </div>
        <div class="flex items-center px-3 sm:px-5 gap-2 <%= comments === 0 ? 'text-gray-400' : '' %>">
          <svg xmlns="http://w3.org" class="h-5 w-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle">
            <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
          </svg>
          <span><%= comments %></span>
        </div>
      </div>
    </div>
  <% }) %>
</main>

<%- include("partials/footer") %>

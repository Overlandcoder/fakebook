<%- include("partials/header") %>

<main class="max-w-xl mx-auto py-12 px-4">
  <div class="bg-white border border-gray-200 rounded-xl shadow-md overflow-hidden">
    <div class="border-b border-gray-100 p-4 bg-gray-50/50">
      <h2 class="text-xl font-bold text-gray-800 text-center">Create Post</h2>
    </div>

    <% if (locals.error) { %>
      <div class="m-4 p-3 bg-red-50 border border-red-100 text-red-600 text-sm rounded-lg">
        <%= error %>
      </div>
    <% } %>

    <form action="/posts" method="POST" class="p-6">
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-full flex items-center justify-center bg-gradient-to-tr from-green-400 to-green-700 text-white font-black shadow-inner">
          <%= currentUser.username[0].toUpperCase() %>
        </div>

        <div class="flex-1">
          <label for="content" class="block text-sm font-semibold text-gray-500 mb-2 uppercase tracking-wider">What's on your mind?</label>
          <textarea name="content" id="content" rows="5" placeholder="Share your thoughts with the community!" class="w-full text-lg border-none focus:ring-0 outline-none resize-none placeholder:text-gray-300" required></textarea>
        </div>
      </div>
      <div class="flex justify-end pt-4 border-t border-gray-100">
        <button type="submit" class="bg-green-600 text-white px-8 py-2 rounded-lg font-bold hover:bg-green-700 transition-colors shadow-sm w-full sm:w-auto active:scale-95">Post</button>
      </div>
    </form>
  </div>

  <div class="mt-6 text-center">
    <a href="/" class="text-sm font-semibold text-gray-400 hover:text-green-600 transition-colors">
      ← Back to Home
    </a>
  </div>
</main>

<%- include("partials/header") %>

<% const labelClasses = "block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2" %>
<% const inputClasses = "w-full px-4 py-3 bg-amber-50/15 border border-amber-200 rounded-md focus:ring-2 focus:ring-green-500 focus:bg-white focus:border-transparent outline-none autofill:bg-amber-50/15 autofill:shadow-[inset_0_0_0px_1000px_#FFFDFB] transition-all" %>

<main class="flex flex-col mt-10 justify-center items-center px-4 py-12">
  <div class="max-w-md w-full bg-white border border-green-300 rounded-lg shadow-xl shadow-green-100 p-8">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-black text-green-600 tracking-tighter mb-2">Fakebook</h1>
      <p class="text-gray-500 font-medium">Welcome back! Please log in.</p>
    </div>

    <% if (locals.error) { %>
      <div class="mb-6 p-3 bg-red-50 border border-red-100 text-red-600 text-sm rounded-lg text-center">
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-5">
      <div>
        <label for="username" class="<%= labelClasses %>">Username</label>
        <input type="text" name="username" id="username" required
          class="<%= inputClasses %>"
          placeholder="Enter your username" />
      </div>

      <div>
        <label for="password" class="<%= labelClasses %>">Password</label>
        <input type="password" name="password" id="password" required
          class="<%= inputClasses %>"
          placeholder="••••••••" />
      </div>

      <button type="submit" class="w-full py-3 bg-green-600 text-white font-bold rounded-full hover:bg-green-700 active:scale-[0.98] transition-all shadow-lg shadow-green-200">Log In</button>
    </form>

    <div class="flex items-center mt-4">
      <div class="border-t border-gray-200 w-1/2"></div>
      <p class="px-8 text-gray-600">or</p>
      <div class="border-t border-gray-200 w-1/2"></div>
    </div>

    <form action="/guest-login" method="POST" class="mt-3">
      <button type="submit" class="w-full py-3 bg-amber-100/50 text-gray-700 font-bold rounded-full hover:bg-amber-200 active:scale-[0.98] transition-all">Log In as Guest</button>
    </form>

    <div class="mt-8 pt-6 border-t border-gray-200 text-center">
      <p class="text-sm text-gray-500">Don't have an account?
        <a href="/signup" class="text-green-600 font-bold hover:underline">Sign Up</a></p>
    </div>
  </div>
</main>

<%- include("partials/footer") %>

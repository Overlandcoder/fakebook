<div class="max-w-xl mx-auto bg-white border-t-4 border-t-green-500 rounded-lg border border-green-300 shadow-md shadow-green-100/80 p-4 my-8">
  <!-- AUTHOR INFO -->
  <div class="flex justify-between items-center mb-3">
    <div class="flex items-center gap-3 min-w-0">
      <a href="/users/<%= post.author.username %>"
        class="font-bold text-green-600 px-2 py-1 rounded-full transition-colors duration-75 hover:bg-green-100 hover:text-green-700 active:scale-95 truncate">
        <%= post.author.username %>
      </a>
      <span class="text-gray-500 flex-shrink-0">
        <%= post.createdAt.toLocaleString([], { 
          month: 'short', 
          day: 'numeric', 
          hour: '2-digit', 
          minute: '2-digit' 
        }) %>
      </span>
    </div>

    <!-- EDIT/DELETE BUTTONS -->
    <% if (currentUser?.username === post.author.username) { %>
      <div class="flex gap-3.5 px-2 flex-shrink-0">
        <button class="edit-btn flex items-center text-gray-400 hover:text-amber-500 transition-colors" data-post-id="<%= post.id %>" title="Edit">
          <svg xmlns="http://w3.org" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </button>
        <form action="/posts/<%= post.id %>?_method=DELETE" method="POST">
          <button type="submit" class="flex items-center text-gray-400 hover:text-red-600 transition-colors" title="Delete">
            <svg xmlns="http://w3.org" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </form>
      </div>
    <% } %>
  </div>

  <!-- POST CONTENT -->
   <div class="p-2 mb-4">
    <% if (post.imageUrl) { %>
      <img src="<%= post.imageUrl %>" alt="Post contains an image by author <%= post.author.username %>" class="mx-auto max-h-96 mb-4 rounded-md">
    <% } %>
    <p id="content-<%= post.id %>" class="text-gray-800 text-lg"><%= post.content %></p>
   </div>

  <!-- EDIT POST FORM -->
  <form id="edit-form-<%= post.id %>" data-post-id="<%= post.id %>" class="edit-form mb-4" style="display: none;">
    <textarea name="content" id="content" class="w-full p-2 border rounded-md text-lg focus:ring-1 focus:ring-green-500 outline-none"><%= post.content %></textarea>
    <div class="flex gap-2 mt-2">
      <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm hover:bg-green-700 transition-colors">Save</button>
      <button type="button" class="cancel-btn bg-gray-100 px-4 py-2 rounded-md text-sm hover:bg-gray-200 transition-colors" data-post-id="<%= post.id %>">Cancel</button>
    </div>
  </form>

  <!-- LIKE SECTION -->
  <div class="border-t pt-2 flex items-center gap-5">
    <% if (currentUser) { %>
      <% const hasUserLiked = post.likes.length > 0 %>
      <% const likeBtnClasses = "flex gap-1.5 items-center px-2.5 py-1 rounded-md hover:bg-amber-50 transition-colors" %>
      <% if (hasUserLiked) { %>
        <form action="/posts/<%= post.id %>/likes?_method=DELETE" method="POST">
          <button type="submit" class="<%= likeBtnClasses %> text-amber-500 font-bold">
            <svg xmlns="http://w3.org" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001Z" />
            </svg>
            Liked
          </button>
        </form>
     <% } else { %>
        <form action="/posts/<%= post.id %>/likes" method="POST">
          <button type="submit" class="<%= likeBtnClasses %> text-gray-600 hover:text-green-700">
            <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
            Like
          </button>
        </form>
      <% } %>
    <% } %>
    <span class="text-gray-500"><%= post._count.likes %> <%= post._count.likes === 1 ? "like" : "likes" %></span>
    <span class="text-gray-500"><%= post._count.comments %> <%= post._count.comments === 1 ? "comment" : "comments" %></span>
  </div>

  <!-- COMMENTS -->
  <% if (post.comments.length > 0) { %>
    <div class="mt-4 space-y-3 mb-5">
      <% post.comments.forEach(comment => { %>
        <div class="bg-amber-50/20 shadow-sm shadow-amber-200/70 px-3 py-2 rounded-xl text-sm max-w-[85%]">
          <a href="/users/<%= comment.author.username %>" class="text-gray-700 font-bold hover:text-green-700">
            <%= comment.author.username %>
          </a>
          <span class="text-gray-700 ml-1.5"><%= comment.content %></span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- NEW COMMENT FORM -->
  <% if (currentUser) { %>
    <form action="/posts/<%= post.id %>/comments" method="POST" class="flex gap-3 mt-4 mb-2">
      <input type="text" name="content" placeholder="Write a comment..." class="flex-grow shadow border border-gray-300 rounded-full px-4 py-2 text-sm outline-none focus:ring-1 focus:border-transparent focus:ring-green-400">
      <button type="submit" class="text-green-600 font-semibold px-3 rounded-md hover:bg-green-100 hover:text-green-700 transition-colors">Post</button>
    </form>
  <% } %>
</div>

<script>
  document.addEventListener("click", (e) => {
    const postId = e.target.dataset.postId;
    if (!postId) return;
    const form = document.getElementById(`edit-form-${postId}`);
    const postPara = document.getElementById(`content-${postId}`);

    if (e.target.classList.contains("edit-btn")) {
      form.style.display = "block";
      postPara.style.display = "none";
    } else if (e.target.classList.contains("cancel-btn")) {
      form.style.display = "none";
      postPara.style.display = "block";
    }
  });

  document.addEventListener("submit", async (e) => {
    const postId = e.target.dataset.postId;
    if (!postId) return;
    e.preventDefault();
    const textArea = e.target.querySelector("textarea");
    const updatedContent = textArea.value;
    const url = `/posts/${postId}`;
    const response = await fetch(url, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ content: updatedContent }),
    });

    if (response.ok) {
      const data = await response.json();
      const postPara = document.getElementById(`content-${postId}`);
      postPara.textContent = data.content;
      e.target.style.display = "none";
      postPara.style.display = "block";
    }
  });
</script>

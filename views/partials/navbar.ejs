<nav class="bg-white sticky top-0 shadow-md">
  <div class="max-w-6xl mx-auto px-4 h-16 flex justify-between items-center">
    <div class="flex items-center gap-2">
      <a href="/" class="text-2xl font-black text-green-600 tracking-tighter hover:text-green-500 transition-colors">Fakebook</a>
    </div>

    <div class="flex items-center gap-5">
      <% if (currentUser) { %>
        <a href="/" class="p-1 sm:px-3 sm:py-2 hover:bg-green-100 hover:text-green-600 rounded-full transition-colors text-gray-600" title="Home">
          <svg xmlns="http://w3.org" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
        <a href="/users/<%= currentUser.username %>" class="flex items-center gap-2 p-1 sm:py-1 sm:px-3 rounded-full transition-colors hover:bg-green-100">
          <div class="w-8 h-8 flex items-center justify-center bg-gradient-to-tr from-green-400 to-green-700 text-white font-bold text-lg rounded-full">
            <%= currentUser.username[0].toUpperCase() %>
          </div>
          <span class="font-semibold text-sm text-gray-700 hidden sm:block"><%= currentUser.username %></span>
        </a>
        <form action="/logout" method="POST">
          <button type="submit" class="flex items-center gap-2 p-1 sm:px-3 sm:py-2 text-sm text-gray-600 rounded-full hover:text-amber-600 hover:bg-amber-50 font-medium transition-all">
            <span class="hidden sm:block">Log Out</span>
            <svg xmlns="http://w3.org" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </button>
        </form>
      <% } else { %>
        <a href="/login" class="px-4 py-2 text-sm font-semibold text-green-600 rounded-lg hover:bg-green-100">Log In</a>
        <a href="/signup" class="px-4 py-2 text-sm font-semibold text-white bg-green-600 rounded-lg hover:bg-green-700">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>
